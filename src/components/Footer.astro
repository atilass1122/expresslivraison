---
import { site } from '../config/site';
import { ROUTES, type Lang } from '../i18n/ui';
import { useTranslations, orderAnchor } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const r = ROUTES[lang];
const privacyHref =
  lang === 'en' ? '/en/info#privacy' : '/informations#confidentialite';
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a class="logo" href={r.home} aria-label={site.name}>
          <img class="logo__img" src="/images/logo-white.png" alt={site.name} width="1017" height="341" />
          <span class="logo__tagline">Sherbrooke<br />0–9 km</span>
        </a>
        <p>{t('footerTagline')}</p>
        <a class="phone-cta" href={`tel:${site.phoneLink}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phoneDisplay}
        </a>
      </div>
      <div>
        <h3>{t('footerNav')}</h3>
        <ul>
          <li><a href={r.home}>{t('navHome')}</a></li>
          <li><a href={r.services}>{t('navServices')}</a></li>
          <li><a href={r.business}>{t('navBusiness')}</a></li>
          <li><a href={r.info}>{t('navInfo')}</a></li>
          <li><a href={r.contact}>{t('navContact')}</a></li>
          <li><a href={orderAnchor(lang)}>{t('navOrder')}</a></li>
        </ul>
      </div>
      <div>
        <h3>{t('footerZonesTitle')}</h3>
        <ul>
          <li>Sherbrooke</li>
          <li>Fleurimont</li>
          <li>Rock Forest</li>
          <li>Saint-Élie-d'Orford</li>
        </ul>
      </div>
      <div>
        <h3>{t('footerContactTitle')}</h3>
        <ul>
          <li><a href={`tel:${site.phoneLink}`}>{site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>{t('footerHoursWeek')}</li>
          <li>{t('footerHoursSun')}</li>
          <li><a href={site.facebook} target="_blank" rel="noopener">{t('footerFacebook')}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© {year} Express Livraison · {t('footerRights')}</span>
      <a href="https://sitewebcreationsr.com/" target="_blank" rel="noopener">{t('footerCredit')}</a>
      <a href={privacyHref}>{t('footerPrivacyLink')}</a>
    </div>
  </div>
</footer>

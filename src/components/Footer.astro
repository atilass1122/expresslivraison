---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a class="logo" href="/" aria-label={site.name}>
          <img class="logo__img" src="/images/logo-white.png" alt={site.name} width="160" height="40" />
          <span class="logo__tagline">Sherbrooke<br />0–9 km</span>
        </a>
        <p>Livraison de dépanneur à domicile à Sherbrooke et ses environs. Tarif fixe, paiement à la porte, 7 jours sur 7.</p>
        <a class="phone-cta" href={`tel:${site.phoneLink}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phoneDisplay}
        </a>
      </div>
      <div>
        <h4>Naviguer</h4>
        <ul>
          <li><a href="/">Accueil</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/entreprises">Entreprises</a></li>
          <li><a href="/informations">Informations</a></li>
          <li><a href="/nous-joindre">Nous joindre</a></li>
          <li><a href="/#commander">Commander en ligne</a></li>
        </ul>
      </div>
      <div>
        <h4>Secteurs · 0–9 km</h4>
        <ul>
          <li>Sherbrooke</li>
          <li>Fleurimont</li>
          <li>Rock Forest</li>
          <li>Saint-Élie-d'Orford</li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li><a href={`tel:${site.phoneLink}`}>{site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>Lun–Sam · 9 h–21 h</li>
          <li>Dim · 10 h–17 h</li>
          <li><a href={site.facebook} target="_blank" rel="noopener">Facebook ↗</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© {year} Express Livraison · Tous droits réservés</span>
      <span>Création SR — Designer Web</span>
      <a href="/informations#confidentialite">Politique de confidentialité</a>
    </div>
  </div>
</footer>

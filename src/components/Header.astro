---
import { site } from '../config/site';

const nav = [
  { label: 'Accueil', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Entreprises', href: '/entreprises' },
  { label: 'Informations', href: '/informations' },
  { label: 'Nous joindre', href: '/nous-joindre' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="topbar">
  <div class="container topbar__inner">
    <a class="logo" href="/" aria-label={`${site.name} · Accueil`}>
      <img class="logo__img" src="/images/logo.png" alt={`${site.name} · livraison locale à Sherbrooke`} width="1017" height="341" />
      <span class="logo__tagline">Sherbrooke<br />0–9 km</span>
    </a>
    <nav class="nav" aria-label="Principal">
      {nav.map(({ label, href }) => {
        const normalized = href.replace(/\/$/, '') || '/';
        const isActive = normalized === currentPath;
        return <a href={href} class:list={[{ active: isActive }]}>{label}</a>;
      })}
    </nav>
    <div class="topbar__cta">
      <a class="phone-cta" href={`tel:${site.phoneLink}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{site.phoneDisplay}</span>
      </a>
      <button class="nav-toggle" data-nav-toggle aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>

---
import { site } from '../config/site';
import { ROUTES, type Lang } from '../i18n/ui';
import { useTranslations, alternateUrl } from '../i18n/utils';

interface Props {
  lang: Lang;
  routeKey?: keyof typeof ROUTES['fr'];
}

const { lang, routeKey } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { label: t('navHome'), href: ROUTES[lang].home, key: 'home' as const },
  { label: t('navServices'), href: ROUTES[lang].services, key: 'services' as const },
  { label: t('navBusiness'), href: ROUTES[lang].business, key: 'business' as const },
  { label: t('navInfo'), href: ROUTES[lang].info, key: 'info' as const },
  { label: t('navContact'), href: ROUTES[lang].contact, key: 'contact' as const },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
const altHref = routeKey ? alternateUrl(routeKey, otherLang) : ROUTES[otherLang].home;
const altLabel = otherLang === 'en' ? 'EN' : 'FR';
const altFull = otherLang === 'en' ? t('switchToEn') : t('switchToFr');
---

<header class="topbar">
  <div class="container topbar__inner">
    <a class="logo" href={ROUTES[lang].home} aria-label={`${site.name} · ${t('homeAria')}`}>
      <img class="logo__img" src="/images/logo.png" alt={site.name} width="1017" height="341" />
      <span class="logo__tagline">Sherbrooke<br />0–9 km</span>
    </a>
    <nav class="nav" aria-label={t('mainNavAria')}>
      {nav.map(({ label, href }) => {
        const normalized = href.replace(/\/$/, '') || '/';
        const isActive = normalized === currentPath;
        return <a href={href} class:list={[{ active: isActive }]}>{label}</a>;
      })}
      <a class="nav__lang" href={altHref} hreflang={otherLang} aria-label={`${t('langSwitcherAria')} · ${altFull}`}>
        <span aria-hidden="true">{altLabel}</span>
        <span class="sr-only">{altFull}</span>
      </a>
    </nav>
    <div class="topbar__cta">
      <a class="lang-toggle" href={altHref} hreflang={otherLang} aria-label={`${t('langSwitcherAria')} · ${altFull}`}>{altLabel}</a>
      <a class="phone-cta" href={`tel:${site.phoneLink}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>{site.phoneDisplay}</span>
      </a>
      <button class="nav-toggle" data-nav-toggle aria-label={t('menuAria')}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>

<style>
  .nav__lang {
    margin-left: 12px;
    padding: 6px 10px;
    border: 1px solid var(--line-strong, rgba(0,0,0,.18));
    border-radius: 999px;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: inherit;
  }
  .nav__lang:hover { background: var(--bg-alt, rgba(0,0,0,.04)); }

  .lang-toggle {
    display: none;
    padding: 8px 12px;
    border: 1px solid var(--line-strong, rgba(0,0,0,.18));
    border-radius: 999px;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: inherit;
    align-items: center;
    justify-content: center;
  }
  .lang-toggle:hover { background: var(--bg-alt, rgba(0,0,0,.04)); }

  @media (max-width: 900px) {
    .nav__lang { display: none; }
    .lang-toggle { display: inline-flex; }
  }
</style>

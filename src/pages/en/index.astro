---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Local convenience store delivery · Sherbrooke"
  description="Home delivery in Sherbrooke: convenience store, restaurants, parcels and essentials. Flat fee $8 / 2 km + $1/km, 7 days a week. Call 873 200-7377."
  bodyClass="page-home"
  lang="en"
  routeKey="home"
>
  <!-- ========== ROUTE BANNER ========== -->
  <section class="route-banner" aria-label="Delivery service in progress">
    <div class="route-banner__wrap">
      <svg class="route-banner__svg" viewBox="0 0 1600 280" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Express Livraison delivery van on the way to the customer in Sherbrooke">
        <defs>
          <linearGradient id="rb-sky" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#0B1B3F"/>
            <stop offset="60%" stop-color="#0A47C2"/>
            <stop offset="100%" stop-color="#2358D6"/>
          </linearGradient>
          <pattern id="rb-grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M40 0H0V40" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
          </pattern>
          <radialGradient id="rb-glow" cx="0.5" cy="0.8" r="0.8">
            <stop offset="0%" stop-color="#4C75DA" stop-opacity="0.5"/>
            <stop offset="60%" stop-color="#4C75DA" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#4C75DA" stop-opacity="0"/>
          </radialGradient>
          <filter id="rb-shadow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="6"/>
            <feOffset dy="6"/>
            <feComponentTransfer><feFuncA type="linear" slope="0.35"/></feComponentTransfer>
            <feMerge><feMergeNode/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <rect width="1600" height="280" fill="url(#rb-sky)"/>
        <rect width="1600" height="280" fill="url(#rb-grid)"/>
        <ellipse cx="800" cy="280" rx="900" ry="240" fill="url(#rb-glow)"/>

        <path d="M0 200 L 180 150 L 320 175 L 460 130 L 620 165 L 780 110 L 940 155 L 1100 125 L 1280 170 L 1440 135 L 1600 165 L 1600 280 L 0 280 Z" fill="rgba(0,0,0,.18)"/>

        <g fill="rgba(0,0,0,.28)">
          <rect x="60" y="170" width="32" height="50"/>
          <rect x="100" y="155" width="22" height="65"/>
          <rect x="128" y="180" width="26" height="40"/>
          <rect x="160" y="145" width="28" height="75"/>
          <rect x="194" y="165" width="20" height="55"/>
          <rect x="220" y="175" width="34" height="45"/>
          <rect x="260" y="160" width="22" height="60"/>

          <rect x="1350" y="165" width="28" height="55"/>
          <rect x="1384" y="150" width="22" height="70"/>
          <rect x="1412" y="170" width="26" height="50"/>
          <rect x="1444" y="155" width="20" height="65"/>
          <rect x="1470" y="178" width="30" height="42"/>
          <rect x="1506" y="160" width="22" height="60"/>
          <rect x="1534" y="172" width="28" height="48"/>
        </g>
        <g fill="rgba(212,228,255,.18)">
          <rect x="66" y="180" width="3" height="3"/><rect x="74" y="180" width="3" height="3"/><rect x="82" y="180" width="3" height="3"/>
          <rect x="66" y="190" width="3" height="3"/><rect x="74" y="190" width="3" height="3"/><rect x="82" y="190" width="3" height="3"/>
          <rect x="104" y="165" width="3" height="3"/><rect x="112" y="165" width="3" height="3"/><rect x="104" y="175" width="3" height="3"/><rect x="112" y="175" width="3" height="3"/>
          <rect x="164" y="155" width="3" height="3"/><rect x="172" y="155" width="3" height="3"/><rect x="180" y="155" width="3" height="3"/>
          <rect x="164" y="165" width="3" height="3"/><rect x="172" y="165" width="3" height="3"/><rect x="180" y="165" width="3" height="3"/>
          <rect x="1390" y="160" width="3" height="3"/><rect x="1398" y="160" width="3" height="3"/>
          <rect x="1390" y="170" width="3" height="3"/><rect x="1398" y="170" width="3" height="3"/>
          <rect x="1450" y="165" width="3" height="3"/><rect x="1458" y="165" width="3" height="3"/>
        </g>

        <rect x="0" y="220" width="1600" height="40" fill="#0E1A38"/>
        <line x1="0" y1="240" x2="1600" y2="240" stroke="#4C75DA" stroke-width="2" stroke-dasharray="24 16" opacity=".7"/>
        <line x1="0" y1="220" x2="1600" y2="220" stroke="rgba(255,255,255,.12)" stroke-width="1"/>

        <g transform="translate(120 130)" filter="url(#rb-shadow)">
          <rect x="0" y="0" width="100" height="90" rx="4" fill="#1A2C5E" stroke="#4C75DA" stroke-width="1"/>
          <rect x="0" y="0" width="100" height="22" fill="#0A47C2"/>
          <text x="50" y="15" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="10" font-weight="600" fill="#fff" letter-spacing="1.5">STORE</text>
          <rect x="12" y="32" width="22" height="28" fill="#4C75DA" opacity=".4"/>
          <rect x="40" y="32" width="22" height="28" fill="#4C75DA" opacity=".4"/>
          <rect x="68" y="32" width="22" height="28" fill="#4C75DA" opacity=".4"/>
          <rect x="40" y="64" width="22" height="26" fill="#0E1A38"/>
          <circle cx="51" cy="78" r="1.5" fill="#FFD54A"/>
          <line x1="0" y1="90" x2="100" y2="90" stroke="#0A1430" stroke-width="2"/>
        </g>
        <g transform="translate(170 110)">
          <circle r="14" fill="#fff"/>
          <circle r="14" fill="none" stroke="#0A47C2" stroke-width="2"/>
          <text y="4" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="#0A47C2" letter-spacing="0.4">A</text>
          <circle r="22" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="1">
            <animate attributeName="r" values="14;28;14" dur="3s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.6;0;0.6" dur="3s" repeatCount="indefinite"/>
          </circle>
        </g>

        <g transform="translate(1380 120)" filter="url(#rb-shadow)">
          <path d="M0 36 L 50 0 L 100 36 L 100 100 L 0 100 Z" fill="#1A2C5E" stroke="#4C75DA" stroke-width="1"/>
          <rect x="36" y="56" width="28" height="44" fill="#0A47C2"/>
          <rect x="44" y="64" width="12" height="20" fill="#FFD54A" opacity=".7"/>
          <rect x="14" y="50" width="14" height="14" fill="#4C75DA" opacity=".5"/>
          <rect x="72" y="50" width="14" height="14" fill="#4C75DA" opacity=".5"/>
          <path d="M0 36 L 50 0 L 100 36" fill="none" stroke="#2358D6" stroke-width="2" stroke-linejoin="round"/>
        </g>
        <g transform="translate(1430 110)">
          <circle r="14" fill="#0A47C2"/>
          <circle r="14" fill="none" stroke="#fff" stroke-width="2"/>
          <text y="4" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" font-weight="700" fill="#fff" letter-spacing="0.4">B</text>
        </g>

        <path d="M 170 220 Q 380 200 540 220 T 1000 220 T 1430 220" stroke="rgba(255,255,255,.18)" stroke-width="3" fill="none"/>
        <path id="rb-route" d="M 170 220 Q 380 200 540 220 T 1000 220 T 1430 220" stroke="#4AFFB8" stroke-width="2" fill="none" stroke-dasharray="6 8" opacity=".7">
          <animate attributeName="stroke-dashoffset" from="0" to="-28" dur="1.2s" repeatCount="indefinite"/>
        </path>

        <g id="rb-van" filter="url(#rb-shadow)">
          <animateMotion dur="14s" repeatCount="indefinite" rotate="0">
            <mpath href="#rb-route-anim"/>
          </animateMotion>
          <g transform="translate(-90 -63)">
            <ellipse cx="90" cy="76" rx="92" ry="4" fill="rgba(0,0,0,.45)"/>
            <path d="M 180 36 L 222 28 L 222 50 L 180 42 Z" fill="#FFE9A8" opacity="0.42"/>
            <path d="M 4 32 L 4 14 Q 4 4 14 4 L 122 4 Q 128 4 128 10 L 128 18 L 140 18 Q 144 18 146 21 L 158 32 L 174 32 Q 180 32 180 38 L 180 56 Q 180 60 176 60 L 164 60 Q 164 46 150 46 Q 136 46 136 60 L 44 60 Q 44 46 30 46 Q 16 46 16 60 L 8 60 Q 4 60 4 56 Z" fill="#fff" stroke="#0E1A38" stroke-width="0.7"/>
            <rect x="6" y="38" width="120" height="4" fill="#0A47C2"/>
            <text x="66" y="22" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700" fill="#0A47C2" letter-spacing="0.4">EXPRESS</text>
            <text x="66" y="36" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700" fill="#0A47C2" letter-spacing="0.4">LIVRAISON</text>
            <text x="66" y="54" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="5" fill="#0A47C2" opacity="0.9" letter-spacing="0.3">873 200-7377</text>
            <line x1="64" y1="4" x2="64" y2="36" stroke="#0E1A38" stroke-width="0.6" opacity="0.45"/>
            <line x1="64" y1="44" x2="64" y2="60" stroke="#0E1A38" stroke-width="0.6" opacity="0.45"/>
            <line x1="128" y1="18" x2="128" y2="60" stroke="#0E1A38" stroke-width="0.6" opacity="0.5"/>
            <rect x="132" y="22" width="13" height="11" rx="1" fill="#7BB4FF" opacity="0.92"/>
            <path d="M 146 22 L 156 31 L 156 33 L 146 33 Z" fill="#7BB4FF" opacity="0.92"/>
            <rect x="145" y="19" width="3" height="3" fill="#0E1A38" opacity="0.75"/>
            <rect x="172" y="34" width="6" height="5" rx="1" fill="#FFE066"/>
            <rect x="172" y="42" width="6" height="2" fill="#0E1A38" opacity="0.55"/>
            <rect x="4" y="34" width="4" height="6" rx="1" fill="#FF5C7A"/>
            <rect x="174" y="54" width="6" height="6" rx="1" fill="#0A39A0"/>
            <rect x="4" y="54" width="6" height="6" rx="1" fill="#0A39A0"/>
            <circle cx="30" cy="60" r="11" fill="#0E1A38"/>
            <circle cx="30" cy="60" r="6" fill="#3A5BD0"/>
            <circle cx="30" cy="60" r="2" fill="#9CE7FF"/>
            <circle cx="150" cy="60" r="11" fill="#0E1A38"/>
            <circle cx="150" cy="60" r="6" fill="#3A5BD0"/>
            <circle cx="150" cy="60" r="2" fill="#9CE7FF"/>
          </g>
        </g>
        <path id="rb-route-anim" d="M 170 220 Q 380 200 540 220 T 1000 220 T 1430 220" fill="none" stroke="none"/>

        <g font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" letter-spacing="1">
          <g transform="translate(380 100)">
            <rect x="-58" y="-18" width="116" height="36" rx="18" fill="rgba(255,255,255,.10)" stroke="rgba(255,255,255,.25)" stroke-width="1"/>
            <text y="-3" text-anchor="middle" fill="#8FAFFF" font-size="9">0–2 KM</text>
            <text y="10" text-anchor="middle" fill="#fff" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">$8</text>
          </g>
          <g transform="translate(680 90)">
            <rect x="-66" y="-18" width="132" height="36" rx="18" fill="rgba(74,255,184,.18)" stroke="#4AFFB8" stroke-width="1"/>
            <text y="-3" text-anchor="middle" fill="#4AFFB8" font-size="9">PER EXTRA KM</text>
            <text y="10" text-anchor="middle" fill="#fff" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">+ $1</text>
          </g>
          <g transform="translate(1000 100)">
            <rect x="-62" y="-18" width="124" height="36" rx="18" fill="rgba(255,255,255,.10)" stroke="rgba(255,255,255,.25)" stroke-width="1"/>
            <text y="-3" text-anchor="middle" fill="#8FAFFF" font-size="9">EST. TIME</text>
            <text y="10" text-anchor="middle" fill="#fff" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">~ 25 MIN</text>
          </g>
          <g transform="translate(1260 90)">
            <rect x="-66" y="-18" width="132" height="36" rx="18" fill="rgba(10,71,194,.55)" stroke="#7BB4FF" stroke-width="1"/>
            <text y="-3" text-anchor="middle" fill="#C7D9FF" font-size="9">MAX RADIUS</text>
            <text y="10" text-anchor="middle" fill="#fff" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">0–9 KM</text>
          </g>
        </g>

        <g transform="translate(1540 36)">
          <circle r="6" fill="#4AFFB8"/>
          <circle r="6" fill="none" stroke="#4AFFB8" stroke-width="1">
            <animate attributeName="r" values="6;14;6" dur="2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.9;0;0.9" dur="2s" repeatCount="indefinite"/>
          </circle>
          <text x="-14" y="4" text-anchor="end" font-family="JetBrains Mono, monospace" font-size="11" font-weight="600" fill="#4AFFB8" letter-spacing="2">LIVE</text>
        </g>

        <g transform="translate(60 36)" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" letter-spacing="2">
          <text fill="#8FAFFF">SHERBROOKE · 7 DAYS · MON–SAT 9 AM–9 PM · SUN 10 AM–5 PM</text>
        </g>
      </svg>
    </div>
  </section>

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <div class="hero__meta">
          <span class="pill pill--live"><span class="dot"></span><span data-status>Open · closes at 9 PM</span></span>
          <span class="pill pill--blue">⌖&nbsp; Sherbrooke · 0–9 km radius</span>
        </div>
        <h1 class="h-display">
          Everything you're missing,<br/>delivered in <span class="hero__highlight">under 30 min.</span>
        </h1>
        <p class="lead">Restaurants, convenience store, small parcels, essentials. Express Livraison picks it up and brings it to your door. One call, one form. Price announced upfront, pay at the door.</p>
        <div class="hero__ctas">
          <a class="btn btn--primary btn--xl" href="tel:+18732007377">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call · 873 200-7377
          </a>
          <a class="btn btn--xl" href="#order">
            Order online <span class="arr">↓</span>
          </a>
        </div>
      </div>

      <aside class="hero__panel" aria-label="Dispatch panel">
        <div class="hero__panel-head">
          <span class="mono">DISPATCH · LIVE</span>
          <span class="hero__panel-pulse" aria-hidden="true"><span></span></span>
        </div>
        <div class="hero__panel-status">
          <div class="hero__panel-stat">
            <div class="mono hero__panel-key">Service status</div>
            <div class="hero__panel-val" data-status>Open · closes at 9 PM</div>
          </div>
          <div class="hero__panel-grid">
            <div>
              <div class="mono hero__panel-key">Area</div>
              <div class="hero__panel-sub">Sherbrooke</div>
            </div>
            <div>
              <div class="mono hero__panel-key">Avg. time</div>
              <div class="hero__panel-sub">~25 min</div>
            </div>
            <div>
              <div class="mono hero__panel-key">Radius</div>
              <div class="hero__panel-sub">0–9 km</div>
            </div>
            <div>
              <div class="mono hero__panel-key">Payment</div>
              <div class="hero__panel-sub">Square + Cash</div>
            </div>
          </div>
        </div>
        <a class="hero__panel-cta" href="tel:+18732007377">
          <div>
            <div class="mono">Dial now</div>
            <div class="hero__panel-num">873 200·7377</div>
          </div>
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <div class="hero__panel-foot">
          <span class="mono">Mon–Sat · 9 AM–9 PM</span>
          <span class="mono">Sun · 10 AM–5 PM</span>
        </div>
      </aside>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section>
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Pricing</div>
          <h2 class="h1" style="margin-top:16px;">One formula.<br/>Calculated by distance.</h2>
        </div>
        <p class="lead section-head__lead">No zones, no complicated tiers. <strong>$8 for 2 km</strong>, then <strong>+$1 for each extra kilometre</strong>. That's it. Items billed at convenience store price.</p>
      </div>

      <div class="formula" data-reveal>
        <div class="formula__part">
          <span class="formula__lbl mono">Base</span>
          <div class="formula__row">
            <div class="formula__val"><span>$</span>8</div>
            <div class="formula__txt">
              <strong>For 2 km</strong>
              <span>Minimum starting fee</span>
            </div>
          </div>
        </div>
        <div class="formula__op" aria-hidden="true">+</div>
        <div class="formula__part">
          <span class="formula__lbl mono">Distance</span>
          <div class="formula__row">
            <div class="formula__val"><span>$</span>1<span class="formula__unit">/km</span></div>
            <div class="formula__txt">
              <strong>Per extra km</strong>
              <span>Beyond the base rate</span>
            </div>
          </div>
        </div>
        <div class="formula__op" aria-hidden="true">=</div>
        <div class="formula__part formula__part--total">
          <span class="formula__lbl mono">Maximum</span>
          <div class="formula__row">
            <div class="formula__val"><span>$</span>15</div>
            <div class="formula__txt">
              <strong>At 9 km (limit)</strong>
              <span>Maximum service radius</span>
            </div>
          </div>
        </div>
      </div>

      <div class="examples" data-reveal>
        <div class="examples__head">
          <span class="mono">Examples · delivery only</span>
          <span class="mono">(item price extra)</span>
        </div>
        <div class="examples__grid">
          <div class="example">
            <div class="example__km mono">2 km</div>
            <div class="example__price"><span>$</span>8</div>
            <div class="example__zone">Downtown</div>
          </div>
          <div class="example">
            <div class="example__km mono">4 km</div>
            <div class="example__price"><span>$</span>10</div>
            <div class="example__zone">Fleurimont</div>
          </div>
          <div class="example example--feat">
            <div class="example__km mono">6 km</div>
            <div class="example__price"><span>$</span>12</div>
            <div class="example__zone">Most popular</div>
          </div>
          <div class="example">
            <div class="example__km mono">8 km</div>
            <div class="example__price"><span>$</span>14</div>
            <div class="example__zone">Rock Forest</div>
          </div>
          <div class="example">
            <div class="example__km mono">9 km</div>
            <div class="example__price"><span>$</span>15</div>
            <div class="example__zone">Saint-Élie</div>
          </div>
        </div>
      </div>

      <p class="tarif__foot mono">* Distance calculated from the store. Taxes applicable on items. Beyond 9 km: call us, we'll assess.</p>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section>
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Our services</div>
          <h2 class="h1" style="margin-top:16px;">Four ways<br/>we can help.</h2>
        </div>
        <p class="lead section-head__lead">We don't just do convenience store runs. Small parcels, essentials, quick errands: anything that can be delivered within 9 km, we'll handle. <strong>Restaurant meals on request</strong> (call us).</p>
      </div>
      <div class="services services--4">
        <a href="/en/services#store" class="service" data-reveal>
          <div class="service__icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h24l-1.5 14a2 2 0 0 1-2 1.8H7.5a2 2 0 0 1-2-1.8z"/><path d="M9 12V8a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v4"/></svg>
          </div>
          <div class="service__num mono">01</div>
          <h3 class="h3">Convenience store</h3>
          <p>Food, drinks, toiletries, lottery. Four families, hundreds of products.</p>
          <span class="pill pill--age">Alcohol · Lottery 18 +</span>
          <span class="service__more">See details <span class="arr">→</span></span>
        </a>
        <a href="/en/services#parcels" class="service" data-reveal>
          <div class="service__icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4l12 6v12l-12 6L4 22V10z"/><path d="M4 10l12 6 12-6M16 16v12"/></svg>
          </div>
          <div class="service__num mono">02</div>
          <h3 class="h3">Small parcels</h3>
          <p>Point A to point B delivery. Documents, keys, forgotten items, errands between neighbours. Discreet and quick.</p>
          <span class="service__more">See details <span class="arr">→</span></span>
        </a>
        <a href="/en/services#essentials" class="service" data-reveal>
          <div class="service__icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4h8v6h6v8h-6v6h-8v-6H6v-8h6z"/></svg>
          </div>
          <div class="service__num mono">03</div>
          <h3 class="h3">Essential items</h3>
          <p>Pharmacy, hygiene, cleaning products, baby items. For when going out isn't an option.</p>
          <span class="service__more">See details <span class="arr">→</span></span>
        </a>
        <a href="/en/services#quick" class="service" data-reveal>
          <div class="service__icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4l-6 14h8l-2 10 10-16h-8z"/></svg>
          </div>
          <div class="service__num mono">04</div>
          <h3 class="h3">Quick errands</h3>
          <p>Anything that doesn't fit other categories, including <strong>restaurant meals on request</strong>. One rule: must be within the 9 km radius.</p>
          <span class="service__more">See details <span class="arr">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== ZONE 0-9 KM ========== -->
  <section style="background:var(--bg-alt);">
    <div class="container">
      <div class="zone-grid" data-reveal>
        <div>
          <div class="kicker">Service area</div>
          <h2 class="h1" style="margin-top:16px;"><span class="zone-num">0 to 9 km</span> radius<br/>around Sherbrooke.</h2>
          <p class="lead" style="margin-top: 24px;">Four boroughs covered. Outside the zone: call us, we'll assess case by case.</p>
          <ul class="zone-list">
            <li><span class="zone-list__dot" style="background:var(--blue-600)"></span> Sherbrooke <span class="mono muted">2 km · $8</span></li>
            <li><span class="zone-list__dot" style="background:var(--blue-500)"></span> Fleurimont <span class="mono muted">~5 km · $11</span></li>
            <li><span class="zone-list__dot" style="background:var(--blue-700)"></span> Rock Forest <span class="mono muted">~7 km · $13</span></li>
            <li><span class="zone-list__dot" style="background:var(--ink)"></span> Saint-Élie-d'Orford <span class="mono muted">~8 km · $14</span></li>
          </ul>
          <div style="margin-top:32px;">
            <a class="btn btn--dark btn--lg" href="tel:+18732007377">Confirm my area <span class="arr">→</span></a>
          </div>
        </div>
        <figure class="zone-map" aria-label="Delivery radius map">
          <svg viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg" role="img">
            <defs>
              <pattern id="grid" x="0" y="0" width="30" height="30" patternUnits="userSpaceOnUse">
                <path d="M30 0H0V30" fill="none" stroke="var(--line)" stroke-width="1"/>
              </pattern>
              <radialGradient id="zone-grad" cx="300" cy="250" r="220" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="var(--blue-600)" stop-opacity="0.18"/>
                <stop offset="50%" stop-color="var(--blue-600)" stop-opacity="0.08"/>
                <stop offset="100%" stop-color="var(--blue-600)" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <rect width="600" height="500" fill="var(--surface)"/>
            <rect width="600" height="500" fill="url(#grid)"/>

            <path d="M0 320 C 120 280, 220 360, 340 310 S 540 270, 600 290"
                  stroke="var(--blue-300)" stroke-width="16" fill="none" opacity=".35" stroke-linecap="round"/>
            <path d="M0 320 C 120 280, 220 360, 340 310 S 540 270, 600 290"
                  stroke="var(--blue-600)" stroke-width="1.5" fill="none" opacity=".6"/>
            <text x="490" y="280" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="2">MAGOG RIV.</text>

            <circle cx="300" cy="250" r="220" fill="url(#zone-grad)"/>
            <circle cx="300" cy="250" r="220" fill="none" stroke="var(--blue-600)" stroke-width="1" stroke-dasharray="4 4" opacity=".4"/>
            <circle cx="300" cy="250" r="150" fill="none" stroke="var(--blue-600)" stroke-width="1" stroke-dasharray="4 4" opacity=".3"/>
            <circle cx="300" cy="250" r="80" fill="none" stroke="var(--blue-600)" stroke-width="1" stroke-dasharray="4 4" opacity=".3"/>

            <g font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">
              <text x="305" y="170" >3 KM</text>
              <text x="305" y="100">6 KM</text>
              <text x="305" y="30">9 KM</text>
            </g>

            <g font-family="Space Grotesk, sans-serif" font-weight="600">
              <circle cx="300" cy="250" r="14" fill="var(--blue-600)" stroke="#fff" stroke-width="3"/>
              <circle cx="300" cy="250" r="40" fill="none" stroke="var(--blue-600)" stroke-width="1.5" opacity=".4">
                <animate attributeName="r" values="14;60;14" dur="3.4s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.7;0;0.7" dur="3.4s" repeatCount="indefinite"/>
              </circle>
              <text x="320" y="245" font-size="18" fill="var(--ink)">Sherbrooke</text>
              <text x="320" y="262" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">CENTRE · 0 KM</text>

              <circle cx="430" cy="170" r="10" fill="var(--blue-500)" stroke="#fff" stroke-width="2.5"/>
              <text x="448" y="167" font-size="15" fill="var(--ink)">Fleurimont</text>
              <text x="448" y="182" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">~5 KM</text>

              <circle cx="180" cy="340" r="10" fill="var(--blue-700)" stroke="#fff" stroke-width="2.5"/>
              <text x="60" y="337" font-size="15" fill="var(--ink)">Rock Forest</text>
              <text x="60" y="352" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">~7 KM</text>

              <circle cx="110" cy="200" r="10" fill="var(--ink)" stroke="#fff" stroke-width="2.5"/>
              <text x="20" y="190" font-size="15" fill="var(--ink)">Saint-Élie</text>
              <text x="20" y="205" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">~8 KM</text>
            </g>

            <g transform="translate(550 60)">
              <circle r="22" fill="var(--surface)" stroke="var(--line-strong)" stroke-width="1"/>
              <path d="M0 -16 L 5 0 L 0 16 L -5 0 Z" fill="var(--primary)" stroke="var(--ink)" stroke-width="1"/>
              <text x="0" y="-26" text-anchor="middle" font-family="JetBrains Mono" font-size="10" font-weight="600" fill="var(--ink)">N</text>
            </g>
            <g transform="translate(40 460)">
              <rect width="48" height="4" fill="var(--ink)"/>
              <rect x="48" width="48" height="4" fill="var(--surface)" stroke="var(--ink)" stroke-width="1"/>
              <text x="0" y="-6" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">0</text>
              <text x="84" y="-6" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">3 KM</text>
            </g>
          </svg>
        </figure>
      </div>
    </div>
  </section>

  <!-- ========== ORDER (form) ========== -->
  <section id="order">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Online order</div>
          <h2 class="h1" style="margin-top:16px;">List your items.<br/>We'll call to confirm.</h2>
        </div>
        <p class="lead section-head__lead">Faster than a phone call for long lists. We'll call the number you provide to confirm the total and arrival time.</p>
      </div>

      <div class="order-grid" data-reveal>
        <form class="order-form" data-form="order" novalidate>
          <div class="order-form__row">
            <div class="field">
              <label for="f-name">Full name <span class="req">*</span></label>
              <input id="f-name" name="name" type="text" required autocomplete="name" placeholder="e.g. Mary Smith" />
              <div class="field__error mono"></div>
            </div>
            <div class="field">
              <label for="f-phone">Mobile phone <span class="req">*</span></label>
              <input id="f-phone" name="phone" type="tel" required data-phone autocomplete="tel" inputmode="tel" placeholder="(873) 200-7377" />
              <div class="field__hint">10-digit Canadian format</div>
              <div class="field__error mono"></div>
            </div>
          </div>

          <div class="order-form__row order-form__row--addr">
            <div class="field" style="flex:2">
              <label for="f-addr">Delivery address <span class="req">*</span></label>
              <input id="f-addr" name="address" type="text" required autocomplete="street-address" placeholder="e.g. 1234 King St West, Apt 5" />
              <div class="field__hint">Street number, street name, apartment</div>
              <div class="field__error mono"></div>
            </div>
            <div class="field" style="flex:1">
              <label for="f-zone">Area <span class="req">*</span></label>
              <select id="f-zone" name="zone" required>
                <option value="">Choose…</option>
                <option>Sherbrooke / centre (~2 km · $8)</option>
                <option>Fleurimont (~5 km · $11)</option>
                <option>Rock Forest (~7 km · $13)</option>
                <option>Saint-Élie-d'Orford (~8 km · $14)</option>
                <option>Outside 9 km · to confirm</option>
              </select>
              <div class="field__error mono"></div>
            </div>
          </div>

          <div class="field">
            <label for="f-order">Item list <span class="req">*</span></label>
            <textarea id="f-order" name="order" required rows="6" placeholder="e.g.&#10;1 × 2% milk 2 L&#10;2 × Coke 591 ml&#10;1 × Lay's BBQ chips&#10;1 × Sliced bread&#10;1 × 6/49 ticket (Wednesday draw)"></textarea>
            <div class="field__hint">Specify brands, formats and quantities. The more precise you are, the faster we go.</div>
            <div class="field__error mono"></div>
          </div>

          <div class="field">
            <label for="f-notes">Notes (optional)</label>
            <input id="f-notes" name="notes" type="text" placeholder="Door code, delivery instructions, etc." />
          </div>

          <label class="checkbox">
            <input type="checkbox" name="age_consent" />
            <span>
              <strong>I confirm I am 18 years or older</strong> for any alcohol or lottery purchase.
              Valid ID will be required upon delivery, without exception.
            </span>
          </label>

          <div class="order-form__submit">
            <button type="submit" class="btn btn--primary btn--xl">
              Send my order
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>
            <span class="mono muted">or call <a href="tel:+18732007377" style="color:var(--primary);text-decoration:underline;">873 200-7377</a></span>
          </div>

          <div class="form-status" data-form-status></div>
        </form>

        <aside class="order-aside">
          <div class="order-aside__card">
            <div class="kicker">Good to know</div>
            <ul class="order-aside__list">
              <li>
                <strong>Phone confirmation</strong>
                <span>We call you back to confirm the total and arrival time, usually within 5 minutes.</span>
              </li>
              <li>
                <strong>Pay at the door</strong>
                <span>Square (debit, credit, contactless) or cash. No online payment.</span>
              </li>
              <li>
                <strong>Age verification</strong>
                <span>For alcohol and lottery: ID required at the door. Without exception.</span>
              </li>
              <li>
                <strong>Item out of stock?</strong>
                <span>We call before heading back. You choose: replace, remove, or wait for the next restock.</span>
              </li>
            </ul>
          </div>
          <div class="order-aside__contact">
            <a class="phone-cta" href="tel:+18732007377" style="width:100%;justify-content:center;padding:14px;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Call 873 200-7377
            </a>
            <div class="order-aside__hours mono">
              <span><strong>Mon–Sat</strong> 9 AM – 9 PM</span>
              <span><strong>Sun</strong> 10 AM – 5 PM</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ========== FAQ SNIPPET ========== -->
  <section>
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Frequently asked</div>
          <h2 class="h1" style="margin-top:16px;">The basics.</h2>
        </div>
        <p class="lead section-head__lead">For details, see the <a href="/en/info" style="text-decoration:underline;color:var(--primary)">Info page</a>.</p>
      </div>
      <div class="faq" data-reveal>
        <details class="faq__item" open>
          <summary><span class="mono faq__num">01</span> Is there a minimum order amount?</summary>
          <div class="faq__answer">No. We deliver even a single item. The flat delivery fee per area stays the same regardless of order size.</div>
        </details>
        <details class="faq__item">
          <summary><span class="mono faq__num">02</span> Do items cost more than at the store?</summary>
          <div class="faq__answer">No. You pay exactly the price posted in store. The flat delivery fee is the only addition. Receipt available on request.</div>
        </details>
        <details class="faq__item">
          <summary><span class="mono faq__num">03</span> How does age verification work?</summary>
          <div class="faq__answer">For alcohol and lottery, a valid ID is required at the door. No exceptions. The driver may refuse delivery if age cannot be verified.</div>
        </details>
        <details class="faq__item">
          <summary><span class="mono faq__num">04</span> What payment methods do you accept?</summary>
          <div class="faq__answer">Square for card (debit, credit, contactless) or cash. No online payment: you pay when we arrive.</div>
        </details>
        <details class="faq__item">
          <summary><span class="mono faq__num">05</span> What happens if an item is out of stock?</summary>
          <div class="faq__answer">We call you before leaving the store. You choose: replace with an equivalent product, remove the item, or wait for the next restock. You never pay for what we don't deliver.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- ========== BIG CTA ========== -->

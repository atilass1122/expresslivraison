---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Business delivery · Sherbrooke"
  description="Delivery for businesses in Sherbrooke: offices, hotels, bars, events, nonprofits. Account, monthly billing, negotiated rate. Reply within 24 h."
  bodyClass="page-entreprises"
  lang="en"
  routeKey="business"
>
  <!-- ========== HERO ========== -->
  <section class="b2b-hero">
    <div class="container b2b-hero__grid">
      <div>
        <div class="hero__meta">
          <span class="pill pill--blue">⌖&nbsp; B2B · Sherbrooke and area</span>
          <span class="pill"><span class="mono">SMB · NONPROFITS · SHOPS</span></span>
        </div>
        <h1 class="h-display" style="font-size:clamp(40px,7vw,88px);">
          The delivery service<br/>
          for your <span class="hero__highlight">team</span>.
        </h1>
        <p class="lead">Shops, offices, hotels, bars, event venues, community organizations. A local, reliable team, reachable during all open hours. Negotiated rate for recurring volume.</p>
        <div class="hero__ctas">
          <a class="btn btn--primary btn--xl" href="#quote">Request a quote <span class="arr">→</span></a>
          <a class="btn btn--xl" href="tel:+18732007377">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Talk to a human
          </a>
        </div>
      </div>
      <aside class="b2b-hero__numbers">
        <div class="b2b-hero__nrow">
          <div>
            <div class="mono b2b-hero__lbl">Avg. response</div>
            <div class="b2b-hero__num">&lt; 24 h</div>
          </div>
          <div>
            <div class="mono b2b-hero__lbl">Coverage</div>
            <div class="b2b-hero__num">0–9 km</div>
          </div>
        </div>
        <div class="b2b-hero__nrow">
          <div>
            <div class="mono b2b-hero__lbl">Billing</div>
            <div class="b2b-hero__num">Monthly</div>
          </div>
          <div>
            <div class="mono b2b-hero__lbl">Commitment</div>
            <div class="b2b-hero__num">None</div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ========== USE CASES ========== -->
  <section style="background:var(--bg-alt);">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Who it's for</div>
          <h2 class="h1" style="margin-top:16px;">Six recurring<br/>use cases.</h2>
        </div>
        <p class="lead section-head__lead">If your team or your customers need something from the convenience store (coffee, paper, supplies, urgent items), we handle it.</p>
      </div>
      <div class="usecases">
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 21h20M3 21V9l9-6 9 6v12M9 21v-8h6v8"/></svg></div>
          <h3 class="h4">Hotels &amp; inns</h3>
          <p>After-hours guest requests (water, snacks, forgotten items). Valet-style service delivered straight to the room.</p>
          <div class="usecase__tag mono">Evening &amp; night</div>
        </article>
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-6 9 6v12H3z"/><path d="M9 21v-6h6v6"/><path d="M3 13h18"/></svg></div>
          <h3 class="h4">Offices &amp; teams</h3>
          <p>Coffee, milk, juice, snacks. Kitchen restock. Weekly or one-off orders.</p>
          <div class="usecase__tag mono">Weekly · ad hoc</div>
        </article>
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
          <h3 class="h4">Bars &amp; restaurants</h3>
          <p>Alcohol top-up, mixers, garnish, toilet paper, soap. When you run out at 8 PM on a Saturday.</p>
          <div class="usecase__tag mono">Urgent restock</div>
        </article>
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div>
          <h3 class="h4">Events &amp; venues</h3>
          <p>Weddings, corporate parties, tournaments. Restock the drinks table without leaving the event.</p>
          <div class="usecase__tag mono">On call</div>
        </article>
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg></div>
          <h3 class="h4">Nonprofits &amp; orgs</h3>
          <p>Coffee, snacks for meetings, water bottles for volunteers, toilet paper for premises. Simple billing.</p>
          <div class="usecase__tag mono">Monthly</div>
        </article>
        <article class="usecase" data-reveal>
          <div class="usecase__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8h14v13M9 11h2M13 11h2M9 15h2M13 15h2"/></svg></div>
          <h3 class="h4">Shops &amp; boutiques</h3>
          <p>Outgoing purchases for your customers or employees. Quick delivery when you can't leave the store.</p>
          <div class="usecase__tag mono">On request</div>
        </article>
      </div>
    </div>
  </section>

  <!-- ========== ADVANTAGES ========== -->
  <section>
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">For business accounts</div>
          <h2 class="h1" style="margin-top:16px;">Partnership<br/>terms.</h2>
        </div>
        <p class="lead section-head__lead">No subscription, no commitment. We structure the partnership around your pace and volume.</p>
      </div>

      <div class="adv-grid" data-reveal>
        <div class="adv">
          <div class="adv__num mono">01</div>
          <h3 class="h3">Business account</h3>
          <p>An internal reference number. We recognize you on the phone, we keep your preferences (delivery address, usual brands, authorized contacts).</p>
        </div>
        <div class="adv">
          <div class="adv__num mono">02</div>
          <h3 class="h3">Monthly billing</h3>
          <p>Detailed summary at the end of each month. Payment via Interac e-transfer or cheque. Receipts available on demand.</p>
        </div>
        <div class="adv">
          <div class="adv__num mono">03</div>
          <h3 class="h3">Negotiated rate</h3>
          <p>For recurring volume (3+ deliveries / week), adjusted delivery rate. Custom quote based on your profile.</p>
        </div>
        <div class="adv">
          <div class="adv__num mono">04</div>
          <h3 class="h3">Priority slots</h3>
          <p>Guaranteed service hours for active accounts. No more panic at 4 PM when coffee runs out for the 5-to-7.</p>
        </div>
        <div class="adv">
          <div class="adv__num mono">05</div>
          <h3 class="h3">Multiple contacts</h3>
          <p>Several people can order on your account (with your authorization). List of authorized names kept up to date.</p>
        </div>
        <div class="adv">
          <div class="adv__num mono">06</div>
          <h3 class="h3">Confidentiality</h3>
          <p>No public transaction. Discreet driver, anonymous package. Your orders stay your business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROCESS ========== -->
  <section style="background:var(--grad-ink);color:#fff;">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker" style="color:#8FAFFF">Onboarding process</div>
          <h2 class="h1" style="margin-top:16px;color:#fff;">From the first call<br/>to the first package.</h2>
        </div>
        <p class="lead section-head__lead" style="color:rgba(255,255,255,.7);">No endless paperwork. One call, a confirmation email, and we're operational the same week.</p>
      </div>
      <ol class="process">
        <li class="process__step">
          <div class="process__num">01</div>
          <div class="process__content">
            <h3 class="h3" style="color:#fff;">You contact us</h3>
            <p>Phone, email, or form. You briefly describe your need (volume, type of items, frequency).</p>
            <span class="mono process__when">Day 1 · 5 min</span>
          </div>
        </li>
        <li class="process__step">
          <div class="process__num">02</div>
          <div class="process__content">
            <h3 class="h3" style="color:#fff;">Custom quote</h3>
            <p>We come back with an adapted price grid, payment terms, and an account number. Within 24 business hours.</p>
            <span class="mono process__when">Day 2 · 24 h</span>
          </div>
        </li>
        <li class="process__step">
          <div class="process__num">03</div>
          <div class="process__content">
            <h3 class="h3" style="color:#fff;">First test order</h3>
            <p>You call us for a first order. We validate the flow: confirmation, delivery, billing.</p>
            <span class="mono process__when">Day 3–7</span>
          </div>
        </li>
        <li class="process__step">
          <div class="process__num">04</div>
          <div class="process__content">
            <h3 class="h3" style="color:#fff;">Ongoing service</h3>
            <p>We recognize you on every call. Monthly summary by email. No commitment: you stop whenever you want.</p>
            <span class="mono process__when">Month 1+</span>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ========== QUOTE FORM ========== -->
  <section id="quote">
    <div class="container">
      <div class="section-head" data-reveal>
        <div>
          <div class="kicker">Quote request</div>
          <h2 class="h1" style="margin-top:16px;">Describe your need.<br/>We reply within 24 h.</h2>
        </div>
        <p class="lead section-head__lead">All fields are indicative. We call back to clarify the rest: we really do prefer to talk to a human rather than a form.</p>
      </div>

      <form class="quote-form" data-form="quote" novalidate data-reveal>
        <div class="quote-form__grid">
          <div class="field">
            <label for="q-company">Company / Organization <span class="req">*</span></label>
            <input id="q-company" name="company" type="text" required placeholder="e.g. Le Pain Doré Bakery" />
          </div>
          <div class="field">
            <label for="q-name">Contact person <span class="req">*</span></label>
            <input id="q-name" name="name" type="text" required placeholder="e.g. Sophie Bélanger" />
          </div>
          <div class="field">
            <label for="q-phone">Phone <span class="req">*</span></label>
            <input id="q-phone" name="phone" type="tel" required data-phone placeholder="(873) 200-7377" />
          </div>
          <div class="field">
            <label for="q-email">Email <span class="req">*</span></label>
            <input id="q-email" name="email" type="email" required placeholder="contact@company.ca" />
          </div>
          <div class="field">
            <label for="q-needs">Type of need <span class="req">*</span></label>
            <select id="q-needs" name="needs" required>
              <option value="">Choose…</option>
              <option>Office restock (coffee, snacks…)</option>
              <option>Hotel / guest room top-up</option>
              <option>Bar / restaurant restock</option>
              <option>Event / venue</option>
              <option>Nonprofit / organization</option>
              <option>Shop / boutique</option>
              <option>Other</option>
            </select>
          </div>
          <div class="field">
            <label for="q-volume">Estimated volume</label>
            <select id="q-volume" name="volume">
              <option value="">Optional…</option>
              <option>One-off · as needed</option>
              <option>1–2 orders / week</option>
              <option>3–5 orders / week</option>
              <option>6+ orders / week</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label for="q-details">Additional details</label>
          <textarea id="q-details" name="details" rows="4" placeholder="Usual delivery address, preferred time slots, recurring items, specifics…"></textarea>
          <div class="field__hint">Any useful detail so we can prepare a precise quote.</div>
        </div>

        <div class="quote-form__submit">
          <button type="submit" class="btn btn--primary btn--xl">
            Send request
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
          <span class="mono muted">Reply within 24 business hours · no commitment</span>
        </div>

        <div class="form-status" data-form-status></div>
      </form>
    </div>
  </section>

  <!-- ========== ALT CONTACT ========== -->
  <section style="background:var(--bg-alt);">
    <div class="container">
      <div class="alt-contact">
        <div>
          <div class="kicker">Prefer the phone?</div>
          <h2 class="h2" style="margin-top:14px;">Call and ask for<br/>the business desk.</h2>
          <p class="lead" style="margin-top:16px;max-width:50ch;">We route you to the right person. No robot, no voice menu.</p>
        </div>
        <div class="alt-contact__card">
          <div class="alt-contact__row">
            <span class="mono muted">Phone</span>
            <a href="tel:+18732007377" class="alt-contact__val">873 200-7377</a>
          </div>
          <div class="alt-contact__row">
            <span class="mono muted">Email</span>
            <a href="mailto:info@expresslivraison.ca" class="alt-contact__val">info@expresslivraison.ca</a>
          </div>
          <div class="alt-contact__row">
            <span class="mono muted">Hours</span>
            <span class="alt-contact__val alt-contact__val--small">Mon–Sat · 9 AM–9 PM · Sun · 10 AM–5 PM</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

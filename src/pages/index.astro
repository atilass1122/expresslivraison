              <circle cx="300" cy="250" r="40" fill="none" stroke="var(--blue-600)" stroke-width="1.5" opacity=".4">
                <animate attributeName="r" values="14;60;14" dur="3.4s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.7;0;0.7" dur="3.4s" repeatCount="indefinite"/>
              </circle>
              <text x="320" y="245" font-size="18" fill="var(--ink)">Sherbrooke</text>
              <text x="320" y="262" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">CENTRE · 0 KM</text>

              <circle cx="430" cy="170" r="10" fill="var(--blue-500)" stroke="#fff" stroke-width="2.5"/>
              <text x="448" y="167" font-size="15" fill="var(--ink)">Fleurimont</text>
              <text x="448" y="182" font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">~5 KM</text>


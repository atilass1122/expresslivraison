    <div class="container">
      <div class="bigcta__box">
        <div>
          <div class="kicker" style="color:rgba(255,255,255,.7);">Prêt à commander ?</div>
          <h2 class="h-display" style="color:#fff;margin-top:16px;font-size:clamp(40px,7vw,88px);">
            Touchez le numéro.<br/>On s'occupe du reste.
          </h2>
          <p class="lead" style="color:rgba(255,255,255,.78);max-width:48ch;margin-top:20px;">Disponible 7 jours sur 7. Réponse rapide, tarif fixe annoncé d'avance.</p>
          <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:32px;">
            <a class="btn btn--primary btn--xl" href="tel:+18732007377" style="background:#fff;color:var(--blue-700);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              873 200-7377
            </a>
            <a class="btn btn--xl" style="background:transparent;color:#fff;border-color:rgba(255,255,255,.3);" href="#commander">
              Commander en ligne
            </a>
          </div>
        </div>
        <div class="bigcta__aside">
          <div class="bigcta__side mono">
            <div><span>BASE</span><strong>8 $</strong></div>
            <div><span>PAR KM</span><strong>+1 $</strong></div>
            <div><span>RAYON</span><strong>0–9 KM</strong></div>
            <div><span>OUVERT</span><strong>7 J/7</strong></div>
          </div>
          <div class="bigcta__pay">
            <div class="bigcta__pay-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></svg>
              <span class="mono">Paiement à la porte</span>
            </div>
            <strong>Square ou comptant</strong>
            <div class="bigcta__pay-tags">
              <span>Débit</span><span>Crédit</span><span>Sans contact</span><span>Comptant</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

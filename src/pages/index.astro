            <circle cx="300" cy="250" r="150" fill="none" stroke="var(--blue-600)" stroke-width="1" stroke-dasharray="4 4" opacity=".3"/>
            <circle cx="300" cy="250" r="80" fill="none" stroke="var(--blue-600)" stroke-width="1" stroke-dasharray="4 4" opacity=".3"/>

            <g font-family="JetBrains Mono, monospace" font-size="10" fill="var(--muted)" letter-spacing="1">
              <text x="305" y="170" >3 KM</text>
              <text x="305" y="100">6 KM</text>
              <text x="305" y="30">9 KM</text>
            </g>

            <g font-family="Space Grotesk, sans-serif" font-weight="600">

---
// Polices auto-hébergées (perf + conformité Loi 25 — plus de requête vers Google).
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/manrope';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import { site } from '../config/site';
import { ui, ROUTES, type Lang } from '../i18n/ui';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  bodyClass?: string;
  lang?: Lang;
  routeKey?: keyof typeof ROUTES['fr'];
}

const detected = getLangFromUrl(Astro.url);
const {
  title,
  description,
  canonical,
  ogImage = '/images/og-image.jpg',
  noindex = false,
  bodyClass = '',
  lang = detected,
  routeKey,
} = Astro.props;

const t = useTranslations(lang);
const localeStrings = ui[lang];

const tagline =
  lang === 'en'
    ? 'Fast local delivery in Sherbrooke'
    : 'Livraison locale rapide à Sherbrooke';

const pageTitle = title ? `${title} | ${site.name}` : `${site.name} · ${tagline}`;
const pageDescription = description || t('siteDescription');
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();

// hreflang : si routeKey fourni, on génère les deux URLs ; sinon fallback canonical.
const frUrl = routeKey ? new URL(ROUTES.fr[routeKey], Astro.site).toString() : canonicalURL;
const enUrl = routeKey ? new URL(ROUTES.en[routeKey], Astro.site).toString() : canonicalURL;

const openingHours = [
  {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '21:00',
  },
  {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: 'Sunday',
    opens: '10:00',
    closes: '17:00',
  },
];

// Données structurées : LocalBusiness (signal pack local) + WebSite.
const structuredData: any[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${site.url}/#business`,
    name: site.name,
    url: site.url,
    telephone: site.phoneLink,
    email: site.email,
    image: `${site.url}/images/og-image.jpg`,
    logo: `${site.url}/images/logo.png`,
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Sherbrooke',
      addressRegion: 'QC',
      addressCountry: 'CA',
    },
    geo: { '@type': 'GeoCoordinates', latitude: 45.4042, longitude: -71.8929 },
    areaServed: ['Sherbrooke', 'Fleurimont', 'Rock Forest', "Saint-Élie-d'Orford"],
    openingHoursSpecification: openingHours,
    sameAs: [site.facebook],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    url: site.url,
    name: site.name,
    inLanguage: localeStrings.htmlLang,
  },
];

// BreadcrumbList — uniquement sur les pages internes (pas la home), pour aider
// Google à afficher un fil d'Ariane dans les résultats de recherche.
const crumbLabels: Record<typeof routeKey & string, { fr: string; en: string }> = {
  home: { fr: 'Accueil', en: 'Home' },
  services: { fr: 'Services', en: 'Services' },
  business: { fr: 'Entreprises', en: 'Business' },
  info: { fr: 'Informations', en: 'Info' },
  contact: { fr: 'Nous joindre', en: 'Contact' },
};
if (routeKey && routeKey !== 'home') {
  const homeLabel = crumbLabels.home[lang];
  const pageLabel = crumbLabels[routeKey][lang];
  structuredData.push({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: homeLabel,
        item: new URL(ROUTES[lang].home, site.url).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: pageLabel,
        item: new URL(ROUTES[lang][routeKey], site.url).toString(),
      },
    ],
  });
}

// Chaînes injectées dans le script client via define:vars.
const jsI18n = {
  statusOpenFmt: localeStrings.statusOpenFmt,
  statusClosedFmt: localeStrings.statusClosedFmt,
  formRequired: localeStrings.formRequired,
  formPhoneInvalid: localeStrings.formPhoneInvalid,
  formFixErrors: localeStrings.formFixErrors,
  formFillRequired: localeStrings.formFillRequired,
  formSubmitting: localeStrings.formSubmitting,
  formOrderOk: localeStrings.formOrderOk,
  formQuoteOk: localeStrings.formQuoteOk,
  formContactOk: localeStrings.formContactOk,
  formSubmitError: localeStrings.formSubmitError,
  formCaptchaRequired: localeStrings.formCaptchaRequired,
  emailOrderSubject: localeStrings.emailOrderSubject,
  emailOrderTitle: localeStrings.emailOrderTitle,
  emailLabelName: localeStrings.emailLabelName,
  emailLabelPhone: localeStrings.emailLabelPhone,
  emailLabelAddress: localeStrings.emailLabelAddress,
  emailLabelZone: localeStrings.emailLabelZone,
  emailLabelOrderList: localeStrings.emailLabelOrderList,
  emailLabelAgeConsent: localeStrings.emailLabelAgeConsent,
  emailValYes: localeStrings.emailValYes,
  emailValNoneRequired: localeStrings.emailValNoneRequired,
  emailLabelNotes: localeStrings.emailLabelNotes,
  emailQuoteSubject: localeStrings.emailQuoteSubject,
  emailQuoteTitle: localeStrings.emailQuoteTitle,
  emailLabelCompany: localeStrings.emailLabelCompany,
  emailLabelContact: localeStrings.emailLabelContact,
  emailLabelEmail: localeStrings.emailLabelEmail,
  emailLabelNeed: localeStrings.emailLabelNeed,
  emailLabelVolume: localeStrings.emailLabelVolume,
  emailLabelDetails: localeStrings.emailLabelDetails,
  emailContactSubjectPrefix: localeStrings.emailContactSubjectPrefix,
  emailContactSubjectDefault: localeStrings.emailContactSubjectDefault,
  emailContactTitle: localeStrings.emailContactTitle,
  emailLabelSubject: localeStrings.emailLabelSubject,
  emailLabelMessage: localeStrings.emailLabelMessage,
};
---

<!doctype html>
<html lang={localeStrings.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- Vérification Google Search Console (conservée de l'ancien site pour garder la propriété vérifiée à la migration) -->
    <meta name="google-site-verification" content="4D9GA4loEMITF5iKhiHEPW86SaegTsZ-Ko-MLyYHGu4" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    }

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="fr-CA" href={frUrl} />
    <link rel="alternate" hreflang="en-CA" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />

    <meta name="theme-color" content="#0A47C2" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={localeStrings.ogLocale} />
    <meta property="og:locale:alternate" content={localeStrings.ogLocaleAlternate} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={site.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Polices auto-hébergées via @fontsource-variable (importées dans le frontmatter). -->

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="sr-only">{t('skipToContent')}</a>
    <Header lang={lang} routeKey={routeKey} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <FloatingCTA lang={lang} />

    <script define:vars={{ I18N: jsI18n, LANG: lang }}>
      // Express Livraison — comportements partagés :
      // nav mobile, révélation au défilement, statut ouvert/fermé en direct,
      // formatage du téléphone (CA) et validation des formulaires.
      (function () {
        const LS = { theme: 'el2.theme', density: 'el2.density' };
        const DEFAULTS = { theme: 'clair', density: 'normal' };
        const read = (k) => {
          try { return localStorage.getItem(LS[k]) || DEFAULTS[k]; }
          catch { return DEFAULTS[k]; }
        };

        function applyAll() {
          const t = read('theme');
          document.documentElement.setAttribute('data-theme', t === 'clair' ? '' : t);
          document.documentElement.setAttribute('data-density', read('density'));
        }
        applyAll();

        // ---------- mobile nav ----------
        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target.closest('[data-nav-toggle]')) {
            document.body.classList.toggle('nav-open');
            return;
          }
          if (target.closest('.nav a')) {
            document.body.classList.remove('nav-open');
          }
        });

        // ---------- reveal on scroll ----------
        const items = document.querySelectorAll('[data-reveal]');
        if (items.length && 'IntersectionObserver' in window) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
            });
          }, { threshold: 0, rootMargin: '0px 0px -10% 0px' });
          items.forEach((el) => io.observe(el));
          setTimeout(() => items.forEach((el) => el.classList.add('in')), 1500);
        } else {
          items.forEach((el) => el.classList.add('in'));
        }

        // ---------- live status (open/closed) ----------
        function fmtHour(h) {
          // FR : '21 h' ; EN : '9 PM'
          if (LANG === 'en') {
            const period = h >= 12 ? 'PM' : 'AM';
            const display = h === 0 ? 12 : h > 12 ? h - 12 : h;
            return display + ' ' + period;
          }
          return h + ' h';
        }
        function updateStatus() {
          const els = document.querySelectorAll('[data-status]');
          if (!els.length) return;
          const d = new Date();
          const isSun = d.getDay() === 0;
          const open = isSun ? 600 : 540;
          const close = isSun ? 1020 : 1260;
          const now = d.getHours() * 60 + d.getMinutes();
          const isOpen = now >= open && now < close;
          els.forEach((el) => {
            if (isOpen) {
              el.textContent = I18N.statusOpenFmt.replace('{h}', fmtHour(Math.floor(close / 60)));
              el.classList.add('is-open');
            } else {
              el.textContent = I18N.statusClosedFmt.replace('{h}', fmtHour(Math.floor(open / 60)));
              el.classList.remove('is-open');
            }
          });
        }
        updateStatus();
        setInterval(updateStatus, 60000);

        // ---------- phone formatting (CA) ----------
        function validatePhoneCA(v) {
          const digits = v.replace(/\D/g, '');
          if (digits.length === 11 && digits[0] === '1') return digits;
          if (digits.length === 10) return '1' + digits;
          return null;
        }
        function formatPhoneCA(v) {
          const d = v.replace(/\D/g, '').slice(0, 10);
          if (d.length === 0) return '';
          if (d.length <= 3) return '(' + d;
          if (d.length <= 6) return '(' + d.slice(0, 3) + ') ' + d.slice(3);
          return '(' + d.slice(0, 3) + ') ' + d.slice(3, 6) + '-' + d.slice(6);
        }
        document.querySelectorAll('input[data-phone]').forEach((inp) => {
          inp.addEventListener('input', () => { inp.value = formatPhoneCA(inp.value); });
        });

        // ---------- Web3Forms submission ----------
        // Clés d'accès — une par type de formulaire, mêmes clés FR + EN.
        // Domaine autorisé : géré dans le tableau de bord web3forms.com.
        const W3F_KEYS = {
          order:   'cd7f730d-bd41-4803-bab9-6d8479239bee',
          quote:   '1da267b8-b9a9-48f9-85f6-c329a9589ce9',
          contact: '156dd479-1675-4caa-b72b-673799d70a40',
        };
        const W3F_ENDPOINT = 'https://api.web3forms.com/submit';

        // Honeypot anti-spam : champ caché que les bots remplissent souvent.
        // Web3Forms ignore les envois où `botcheck` est non vide.
        function ensureHoneypot(form) {
          if (form.querySelector('input[name="botcheck"]')) return;
          const h = document.createElement('input');
          h.type = 'checkbox';
          h.name = 'botcheck';
          h.tabIndex = -1;
          h.setAttribute('aria-hidden', 'true');
          h.style.cssText = 'position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none;';
          form.appendChild(h);
        }

        async function submitWeb3Forms(form, accessKey, subject, body, okHtml) {
          const status = form.querySelector('[data-form-status]');
          const submitBtn = form.querySelector('button[type="submit"]');
          const originalBtnText = submitBtn ? submitBtn.innerHTML : '';

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = I18N.formSubmitting;
          }
          if (status) {
            status.textContent = I18N.formSubmitting;
            status.className = 'form-status';
          }

          const payload = new FormData();
          payload.append('access_key', accessKey);
          payload.append('subject', subject);
          payload.append('from_name', form.querySelector('[name="name"]')?.value || 'Express Livraison');
          const emailField = form.querySelector('[name="email"]');
          if (emailField && emailField.value) payload.append('replyto', emailField.value);
          payload.append('message', body);
          // Copier également chaque champ utile pour qu'ils apparaissent dans le tableau de bord.
          new FormData(form).forEach((v, k) => {
            if (k === 'access_key' || k === 'message' || k === 'subject' || k === 'from_name' || k === 'replyto') return;
            payload.append(k, v);
          });

          try {
            const res = await fetch(W3F_ENDPOINT, { method: 'POST', body: payload });
            const data = await res.json().catch(() => ({}));
            if (res.ok && data.success) {
              if (status) {
                status.innerHTML = okHtml;
                status.className = 'form-status form-status--ok';
              }
              form.reset();
              if (submitBtn) submitBtn.innerHTML = originalBtnText;
              // Garder le bouton désactivé brièvement pour éviter les doubles envois.
              setTimeout(() => { if (submitBtn) submitBtn.disabled = false; }, 1500);
              return true;
            }
            throw new Error((data && data.message) || ('HTTP ' + res.status));
          } catch (err) {
            if (status) {
              status.innerHTML = I18N.formSubmitError;
              status.className = 'form-status form-status--err';
            }
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalBtnText;
            }
            return false;
          }
        }

        // Anti-spam : seulement un honeypot silencieux (aucune friction utilisateur).
        // Web3Forms rejette automatiquement tout envoi où `botcheck` est rempli.
        const managedForms = document.querySelectorAll('[data-form="order"], [data-form="quote"], [data-form="contact"]');
        managedForms.forEach((form) => ensureHoneypot(form));

        // ---------- order form ----------
        document.querySelectorAll('[data-form="order"]').forEach((form) => {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              const errEl = wrap ? wrap.querySelector('.field__error') : null;
              wrap && wrap.classList.remove('field--error');
              if (inp.type === 'checkbox') {
                if (!inp.checked) { wrap && wrap.classList.add('field--error'); ok = false; }
                return;
              }
              if (!inp.value.trim()) {
                wrap && wrap.classList.add('field--error');
                if (errEl) errEl.textContent = I18N.formRequired;
                ok = false;
                return;
              }
              if (inp.dataset.phone) {
                if (!validatePhoneCA(inp.value)) {
                  wrap && wrap.classList.add('field--error');
                  if (errEl) errEl.textContent = I18N.formPhoneInvalid;
                  ok = false;
                }
              }
            });

            const orderField = form.querySelector('[name="order"]');
            const ageBox = form.querySelector('[name="age_consent"]');
            if (ageBox && orderField) {
              const mentions18 = /(biere|bière|alcool|vodka|gin|rhum|loto|loter|vin|spiritu|beer|wine|liquor|spirit|lottery)/i.test(orderField.value);
              if (mentions18 && !ageBox.checked) {
                const wrap = ageBox.closest('.checkbox');
                wrap && wrap.classList.add('field--error');
                ok = false;
              }
            }

            if (!ok) {
              const status = form.querySelector('[data-form-status]');
              if (status) {
                status.textContent = I18N.formFixErrors;
                status.className = 'form-status form-status--err';
              }
              return;
            }

            const fd = new FormData(form);
            const body =
              I18N.emailOrderTitle + '\n' +
              '────────────────────────\n' +
              I18N.emailLabelName + '         : ' + (fd.get('name') || '') + '\n' +
              I18N.emailLabelPhone + '   : ' + (fd.get('phone') || '') + '\n' +
              I18N.emailLabelAddress + '     : ' + (fd.get('address') || '') + '\n' +
              I18N.emailLabelZone + '     : ' + (fd.get('zone') || '') + '\n' +
              '\n' + I18N.emailLabelOrderList + '\n' +
              '────────────────────────\n' +
              (fd.get('order') || '') + '\n' +
              '\n' + I18N.emailLabelAgeConsent + ' : ' + (fd.get('age_consent') ? I18N.emailValYes : I18N.emailValNoneRequired) + '\n' +
              I18N.emailLabelNotes + ' : ' + (fd.get('notes') || '') + '\n';

            await submitWeb3Forms(form, W3F_KEYS.order, I18N.emailOrderSubject, body, I18N.formOrderOk);
          });
        });

        // ---------- B2B quote form ----------
        document.querySelectorAll('[data-form="quote"]').forEach((form) => {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              wrap && wrap.classList.remove('field--error');
              if (!inp.value.trim()) { wrap && wrap.classList.add('field--error'); ok = false; }
            });
            if (!ok) {
              const status = form.querySelector('[data-form-status]');
              if (status) { status.textContent = I18N.formFillRequired; status.className = 'form-status form-status--err'; }
              return;
            }
            const fd = new FormData(form);
            const body =
              I18N.emailQuoteTitle + '\n' +
              '────────────────────────\n' +
              I18N.emailLabelCompany + '  : ' + (fd.get('company') || '') + '\n' +
              I18N.emailLabelContact + '     : ' + (fd.get('name') || '') + '\n' +
              I18N.emailLabelPhone + '   : ' + (fd.get('phone') || '') + '\n' +
              I18N.emailLabelEmail + '    : ' + (fd.get('email') || '') + '\n' +
              I18N.emailLabelNeed + '      : ' + (fd.get('needs') || '') + '\n' +
              I18N.emailLabelVolume + '      : ' + (fd.get('volume') || '') + '\n' +
              I18N.emailLabelDetails + '     :\n' + (fd.get('details') || '') + '\n';
            await submitWeb3Forms(form, W3F_KEYS.quote, I18N.emailQuoteSubject, body, I18N.formQuoteOk);
          });
        });

        // ---------- general contact form ----------
        document.querySelectorAll('[data-form="contact"]').forEach((form) => {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              wrap && wrap.classList.remove('field--error');
              if (!inp.value.trim()) { wrap && wrap.classList.add('field--error'); ok = false; }
            });
            if (!ok) {
              const status = form.querySelector('[data-form-status]');
              if (status) { status.textContent = I18N.formFillRequired; status.className = 'form-status form-status--err'; }
              return;
            }
            const fd = new FormData(form);
            const body =
              I18N.emailContactTitle + '\n' +
              '────────────────────────\n' +
              I18N.emailLabelName + '       : ' + (fd.get('name') || '') + '\n' +
              I18N.emailLabelEmail + '  : ' + (fd.get('email') || '') + '\n' +
              I18N.emailLabelPhone + ' : ' + (fd.get('phone') || '') + '\n' +
              I18N.emailLabelSubject + '     : ' + (fd.get('subject') || '') + '\n' +
              '\n' + I18N.emailLabelMessage + '   :\n' + (fd.get('message') || '') + '\n';
            const subject = I18N.emailContactSubjectPrefix + (fd.get('subject') || I18N.emailContactSubjectDefault);
            await submitWeb3Forms(form, W3F_KEYS.contact, subject, body, I18N.formContactOk);
          });
        });
      })();
    </script>
  </body>
</html>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = site.description,
  canonical,
  ogImage = '/images/og-image.jpg',
  noindex = false,
  bodyClass = '',
} = Astro.props;

const pageTitle = title ? `${title} | ${site.name}` : `${site.name} — ${site.tagline}`;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();

const deliveryServiceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DeliveryService',
  name: site.name,
  url: site.url,
  telephone: site.phoneLink,
  email: site.email,
  areaServed: ['Sherbrooke', 'Fleurimont', 'Rock Forest', "Saint-Élie-d'Orford"],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '21:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Sunday',
      opens: '10:00',
      closes: '17:00',
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#0A47C2" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts — Space Grotesk (display) + Manrope (body) + JetBrains Mono (data) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(deliveryServiceJsonLd)} />
  </head>
  <body class={bodyClass}>
    <a href="#main" class="sr-only">Aller au contenu principal</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCTA />

    <script>
      // Express Livraison — comportements partagés :
      // nav mobile, révélation au défilement, statut ouvert/fermé en direct,
      // formatage du téléphone (CA) et validation des formulaires.
      (function () {
        const LS = { theme: 'el2.theme', density: 'el2.density' };
        const DEFAULTS: Record<string, string> = { theme: 'clair', density: 'normal' };
        const read = (k: string) => {
          try { return localStorage.getItem(LS[k as keyof typeof LS]) || DEFAULTS[k]; }
          catch { return DEFAULTS[k]; }
        };

        function applyAll() {
          const t = read('theme');
          document.documentElement.setAttribute('data-theme', t === 'clair' ? '' : t);
          document.documentElement.setAttribute('data-density', read('density'));
        }
        applyAll();

        // ---------- mobile nav ----------
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('[data-nav-toggle]')) {
            document.body.classList.toggle('nav-open');
            return;
          }
          if (target.closest('.nav a')) {
            document.body.classList.remove('nav-open');
          }
        });

        // ---------- reveal on scroll ----------
        const items = document.querySelectorAll('[data-reveal]');
        if (items.length && 'IntersectionObserver' in window) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add('in');
                io.unobserve(en.target);
              }
            });
          }, { threshold: 0, rootMargin: '0px 0px -10% 0px' });
          items.forEach((el) => io.observe(el));
          setTimeout(() => items.forEach((el) => el.classList.add('in')), 1500);
        } else {
          items.forEach((el) => el.classList.add('in'));
        }

        // ---------- live status (open/closed) ----------
        function updateStatus() {
          const els = document.querySelectorAll('[data-status]');
          if (!els.length) return;
          const d = new Date();
          const isSun = d.getDay() === 0;
          const open = isSun ? 600 : 540;
          const close = isSun ? 1020 : 1260;
          const now = d.getHours() * 60 + d.getMinutes();
          const isOpen = now >= open && now < close;
          els.forEach((el) => {
            if (isOpen) {
              el.textContent = 'Ouvert · ferme à ' + Math.floor(close / 60) + ' h';
              el.classList.add('is-open');
            } else {
              el.textContent = 'Fermé · ouvre à ' + Math.floor(open / 60) + ' h';
              el.classList.remove('is-open');
            }
          });
        }
        updateStatus();
        setInterval(updateStatus, 60000);

        // ---------- phone formatting (CA) ----------
        function validatePhoneCA(v: string) {
          const digits = v.replace(/\D/g, '');
          if (digits.length === 11 && digits[0] === '1') return digits;
          if (digits.length === 10) return '1' + digits;
          return null;
        }
        function formatPhoneCA(v: string) {
          const d = v.replace(/\D/g, '').slice(0, 10);
          if (d.length === 0) return '';
          if (d.length <= 3) return '(' + d;
          if (d.length <= 6) return '(' + d.slice(0, 3) + ') ' + d.slice(3);
          return '(' + d.slice(0, 3) + ') ' + d.slice(3, 6) + '-' + d.slice(6);
        }
        document.querySelectorAll<HTMLInputElement>('input[data-phone]').forEach((inp) => {
          inp.addEventListener('input', () => { inp.value = formatPhoneCA(inp.value); });
        });

        // ---------- order form validation ----------
        document.querySelectorAll<HTMLFormElement>('[data-form="order"]').forEach((form) => {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll<HTMLInputElement>('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              const errEl = wrap ? wrap.querySelector('.field__error') : null;
              wrap?.classList.remove('field--error');
              if (inp.type === 'checkbox') {
                if (!inp.checked) { wrap?.classList.add('field--error'); ok = false; }
                return;
              }
              if (!inp.value.trim()) {
                wrap?.classList.add('field--error');
                if (errEl) errEl.textContent = 'Champ requis';
                ok = false;
                return;
              }
              if (inp.dataset.phone) {
                if (!validatePhoneCA(inp.value)) {
                  wrap?.classList.add('field--error');
                  if (errEl) errEl.textContent = 'Numéro canadien à 10 chiffres requis';
                  ok = false;
                }
              }
            });

            const orderField = form.querySelector<HTMLTextAreaElement>('[name="order"]');
            const ageBox = form.querySelector<HTMLInputElement>('[name="age_consent"]');
            if (ageBox && orderField) {
              const mentions18 = /(biere|bière|alcool|vodka|gin|rhum|cigar|cigare|tabac|loto|loter|vin|spiritu)/i.test(orderField.value);
              if (mentions18 && !ageBox.checked) {
                ageBox.closest('.checkbox')?.classList.add('field--error');
                ok = false;
              }
            }

            const status = form.querySelector('[data-form-status]');
            if (!ok) {
              if (status) {
                status.textContent = 'Merci de corriger les champs en rouge.';
                status.className = 'form-status form-status--err';
              }
              return;
            }

            const fd = new FormData(form);
            const subject = 'Nouvelle commande — Express Livraison';
            const body =
              'NOUVELLE COMMANDE\n' +
              '────────────────────────\n' +
              'Nom         : ' + (fd.get('name') || '') + '\n' +
              'Téléphone   : ' + (fd.get('phone') || '') + '\n' +
              'Adresse     : ' + (fd.get('address') || '') + '\n' +
              'Secteur     : ' + (fd.get('zone') || '') + '\n' +
              "\nLISTE D'ARTICLES\n" +
              '────────────────────────\n' +
              (fd.get('order') || '') + '\n' +
              '\nConsentement 18+ : ' + (fd.get('age_consent') ? 'Oui' : 'Non requis') + '\n' +
              'Notes : ' + (fd.get('notes') || '') + '\n';

            const mailto = 'mailto:info@expresslivraison.ca?subject=' +
              encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
            if (status) {
              status.innerHTML = "✓ Formulaire validé. Votre client courriel s'ouvre — ou appelez le <a href=\"tel:+18732007377\"><strong>873 200-7377</strong></a> directement.";
              status.className = 'form-status form-status--ok';
            }
            window.location.href = mailto;
          });
        });

        // ---------- B2B quote form ----------
        document.querySelectorAll<HTMLFormElement>('[data-form="quote"]').forEach((form) => {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll<HTMLInputElement>('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              wrap?.classList.remove('field--error');
              if (!inp.value.trim()) { wrap?.classList.add('field--error'); ok = false; }
            });
            const status = form.querySelector('[data-form-status]');
            if (!ok) {
              if (status) { status.textContent = 'Merci de remplir les champs requis.'; status.className = 'form-status form-status--err'; }
              return;
            }
            const fd = new FormData(form);
            const body =
              'DEMANDE DE SOUMISSION B2B\n' +
              '────────────────────────\n' +
              'Entreprise  : ' + (fd.get('company') || '') + '\n' +
              'Contact     : ' + (fd.get('name') || '') + '\n' +
              'Téléphone   : ' + (fd.get('phone') || '') + '\n' +
              'Courriel    : ' + (fd.get('email') || '') + '\n' +
              'Besoin      : ' + (fd.get('needs') || '') + '\n' +
              'Volume      : ' + (fd.get('volume') || '') + '\n' +
              'Détails     :\n' + (fd.get('details') || '') + '\n';
            const mailto = 'mailto:info@expresslivraison.ca?subject=' +
              encodeURIComponent('Demande soumission B2B — Express Livraison') +
              '&body=' + encodeURIComponent(body);
            if (status) {
              status.innerHTML = "✓ Demande validée. Votre client courriel s'ouvre. Nous répondons dans les 24 h ouvrables.";
              status.className = 'form-status form-status--ok';
            }
            window.location.href = mailto;
          });
        });

        // ---------- general contact form ----------
        document.querySelectorAll<HTMLFormElement>('[data-form="contact"]').forEach((form) => {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            let ok = true;
            form.querySelectorAll<HTMLInputElement>('[required]').forEach((inp) => {
              const wrap = inp.closest('.field');
              wrap?.classList.remove('field--error');
              if (!inp.value.trim()) { wrap?.classList.add('field--error'); ok = false; }
            });
            const status = form.querySelector('[data-form-status]');
            if (!ok) {
              if (status) { status.textContent = 'Merci de remplir les champs requis.'; status.className = 'form-status form-status--err'; }
              return;
            }
            const fd = new FormData(form);
            const body =
              'MESSAGE — SITE WEB\n' +
              '────────────────────────\n' +
              'Nom       : ' + (fd.get('name') || '') + '\n' +
              'Courriel  : ' + (fd.get('email') || '') + '\n' +
              'Téléphone : ' + (fd.get('phone') || '') + '\n' +
              'Sujet     : ' + (fd.get('subject') || '') + '\n' +
              '\nMessage   :\n' + (fd.get('message') || '') + '\n';
            const mailto = 'mailto:info@expresslivraison.ca?subject=' +
              encodeURIComponent('Message site web — ' + (fd.get('subject') || 'Contact')) +
              '&body=' + encodeURIComponent(body);
            if (status) {
              status.innerHTML = "✓ Message validé. Votre client courriel s'ouvre. Réponse sous 24 h ouvrables.";
              status.className = 'form-status form-status--ok';
            }
            window.location.href = mailto;
          });
        });
      })();
    </script>
  </body>
</html>
